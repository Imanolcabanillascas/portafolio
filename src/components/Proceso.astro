---
const pasos = [
  {
    numero: "01",
    emoji: "1️⃣",
    titulo: "Analizamos tu negocio",
    descripcion: "Entendemos tus objetivos, tu público y tu competencia para construir una solución a medida.",
  },
  {
    numero: "02",
    emoji: "2️⃣",
    titulo: "Diseñamos la web",
    descripcion: "Creamos un diseño moderno, atractivo y alineado con tu marca antes de escribir una sola línea de código.",
  },
  {
    numero: "03",
    emoji: "3️⃣",
    titulo: "Desarrollamos y optimizamos",
    descripcion: "Construimos tu web con tecnologías modernas, optimizada para velocidad, SEO y dispositivos móviles.",
  },
  {
    numero: "04",
    emoji: "4️⃣",
    titulo: "Lanzamiento",
    descripcion: "Publicamos tu web, hacemos pruebas finales y te entregamos lista para recibir clientes.",
  },
];
---

<section id="proceso" class="relative z-0 py-24 px-4">
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-xs tracking-[0.4em] uppercase text-white/30 mb-3">Paso a paso</p>
      <h2 class="text-4xl md:text-5xl font-light text-white mb-4">Cómo trabajamos</h2>
      <div class="h-px w-16 bg-white/20 mx-auto"></div>
    </div>

    <!-- Pasos desktop: línea conectora -->
    <div class="hidden md:flex items-start justify-between relative mb-4">

      <!-- Línea conectora -->
      <div class="absolute top-8 left-[10%] right-[10%] h-px bg-white/10 z-0">
        <div class="h-full bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
      </div>

      {pasos.map((paso) => (
        <div class="relative z-10 flex flex-col items-center text-center w-1/4 px-4 group">

          <!-- Círculo número -->
          <div class="w-16 h-16 rounded-full border border-white/20 bg-[#03134e] flex items-center justify-center mb-6 group-hover:border-white/50 group-hover:bg-white/10 transition-all duration-300">
            <span class="text-2xl">{paso.emoji}</span>
          </div>

          <!-- Número pequeño -->
          <span class="text-xs tracking-widest uppercase text-white/20 mb-2">{paso.numero}</span>

          <!-- Título -->
          <h3 class="text-white font-medium text-sm mb-3 leading-snug">{paso.titulo}</h3>

          <!-- Descripción -->
          <p class="text-white/40 text-xs leading-relaxed">{paso.descripcion}</p>

        </div>
      ))}
    </div>

    <!-- Pasos mobile: vertical -->
    <div class="flex md:hidden flex-col gap-0">
      {pasos.map((paso, i) => (
        <div class="flex gap-5 items-start">

          <!-- Línea vertical + círculo -->
          <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full border border-white/20 bg-[#03134e] flex items-center justify-center shrink-0">
              <span class="text-xl">{paso.emoji}</span>
            </div>
            {i < pasos.length - 1 && (
              <div class="w-px h-12 bg-white/10 my-1"></div>
            )}
          </div>

          <!-- Contenido -->
          <div class="pb-10">
            <span class="text-xs tracking-widest uppercase text-white/20 block mb-1">{paso.numero}</span>
            <h3 class="text-white font-medium text-sm mb-2">{paso.titulo}</h3>
            <p class="text-white/40 text-xs leading-relaxed">{paso.descripcion}</p>
          </div>

        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <a href="#contacto" class="inline-block text-xs tracking-widest uppercase bg-white/10 border border-white/20 text-white px-8 py-3 hover:bg-white hover:text-[#03134e] transition-all duration-300">
        Empezar ahora
      </a>
    </div>

  </div>
</section>