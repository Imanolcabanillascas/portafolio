---
const servicios = [
  {
    titulo: "Landing Pages",
    icono: "⚡",
    caracteristicas: [
      "Diseño optimizado para conversión",
      "Responsive",
      "Integración WhatsApp",
    ],
  },
  {
    titulo: "Web para Negocios",
    icono: "🏢",
    caracteristicas: [
      "Página corporativa",
      "SEO básico",
      "Panel de administración",
    ],
  },
  {
    titulo: "Optimización Web",
    icono: "🚀",
    caracteristicas: [
      "Mejorar velocidad",
      "Mejor UX",
      "SEO técnico",
    ],
  },
];
---

<section id="servicios" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-xs tracking-[0.4em] uppercase text-white/30 mb-4">Lo que ofrezco</p>
      <h2 class="text-4xl md:text-5xl font-light text-white mb-4">Servicios</h2>
      <div class="h-px w-16 bg-white/20 mx-auto"></div>
    </div>

    <!-- Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {servicios.map((servicio, i) => (
        <div class="group relative border border-white/10 p-8 hover:border-white/30 transition-all duration-300 hover:-translate-y-1">

          <!-- Número decorativo -->
          <span class="absolute top-4 right-5 text-white/5 text-6xl font-bold select-none">
            {String(i + 1).padStart(2, '0')}
          </span>

          <!-- Icono -->
          <div class="text-3xl mb-6">{servicio.icono}</div>

          <!-- Título -->
          <h3 class="text-lg font-medium text-white mb-6 tracking-wide">
            {servicio.titulo}
          </h3>

          <!-- Divisor -->
          <div class="h-px w-8 bg-white/20 mb-6 group-hover:w-16 transition-all duration-300"></div>

          <!-- Características -->
          <ul class="flex flex-col gap-3">
            {servicio.caracteristicas.map(item => (
              <li class="flex items-start gap-3 text-sm text-white/50">
                <span class="text-white/30 mt-0.5 shrink-0">→</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>

        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-16">
      <p class="text-white/30 text-sm mb-6 tracking-wide">
        ¿Necesitas alguno de estos servicios?
      </p>
      <a href="#contacto" class="inline-block text-xs tracking-widest uppercase border border-white/20 text-white/60 px-8 py-3 hover:border-white hover:text-white transition-all duration-300">
        Hablemos
      </a>
    </div>

  </div>
</section>