---
import Navbar from '../components/Navbar.astro';
import Title from '../components/Title.astro';
import Carrousel from '../components/Carrousel.astro';
import HeroImadev from '../components/HeroImadev.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

import "../styles/global.css";

const cards = [
  {
    title: "BarberWeb",
    description: "Página web para tu barbería.",
    image: "/images/barber_web.svg",
    link: "https://barberwebimanolcab.netlify.app/",
  },
  {
    title: "FoodWeb",
    description: "Página web para tu negocio de venta de comida.",
    image: "/images/food_web.svg",
    link: "https://webrestaurantimanolcab.netlify.app/",
  },
  {
    title: "StoreWeb",
    description: "Página web para tu negocio de venta de ropa.",
    image: "/images/store_web.svg",
    link: "https://webshoesimanolcab.netlify.app/",
  },
  {
    title: "MovieWeb",
    description: "Página web de peliculas y series.",
    image: "/images/movie_web.svg",
    link: "https://paginadereck.netlify.app/",
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/images/logo_ima_web.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Imadev - Desarrollo web profesional. Páginas web modernas para tu negocio." />
    <meta name="keywords" content="desarrollo web, páginas web, lima, perú, imadev" />
    <meta property="og:title" content="Imadev" />
    <meta property="og:description" content="Desarrollo web profesional. Páginas web modernas para tu negocio." />
    <meta property="og:image" content="/images/logo_ima_web.svg" />
    <title>Imadev</title>
  </head>
  <body class="min-h-screen bg-[#03134e]">

    <!-- Fondo de esferas transparentes -->
    <div class="spheres-bg" aria-hidden="true">
      <div class="sphere sphere-1"></div>
      <div class="sphere sphere-2"></div>
      <div class="sphere sphere-3"></div>
      <div class="sphere sphere-4"></div>
      <div class="sphere sphere-7"></div>
    </div>

    <!-- Contenido principal encima de las esferas -->
    <div class="relative z-10">
      <Navbar />
      <HeroImadev />
      <Carrousel {cards} />
      <Contact />
      <Footer />
    </div>

    <!-- Botón flotante WhatsApp -->
    
      href="https://wa.me/51961329036"
      target="_blank"
      class="fixed bottom-6 right-6 z-50 bg-green-500 hover:bg-green-400 text-white rounded-full p-4 shadow-lg shadow-green-500/30 transition-all duration-300 hover:scale-110"
      aria-label="WhatsApp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 0a12 12 0 00-9.44 19.2L1.5 24l5.08-1.34A11.92 11.92 0 0012 24a12 12 0 000-24zm6.6 17.2c-.28.8-1.63 1.5-2.27 1.58s-.53.5-3.14-.65c-2.65-1.16-4.32-3.73-4.45-3.9a5.5 5.5 0 01-1.17-2.55c-.12-.58.28-1.26.43-1.44s.38-.32.57-.4a.72.72 0 01.5 0l.4.06c.12 0 .3-.05.47.35.18.43.58 1.44.63 1.54s.1.25 0 .4-.16.25-.3.38c-.15.12-.3.27-.43.4s-.18.27-.08.44a8.3 8.3 0 001.53 1.97 7.28 7.28 0 002.32 1.5c.28.1.45.08.6-.05s.7-.8.9-1.08.4-.25.65-.15 1.68.8 1.97.95.48.22.55.35c.07.12.07.7-.22 1.48z"/>
      </svg>
    </a>

  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  /* Contenedor fijo del fondo */
  .spheres-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  /* Esfera base */
  .sphere {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: radial-gradient(
      circle at 30% 30%,
      rgba(255, 255, 255, 0.06) 0%,
      rgba(255, 255, 255, 0.01) 60%,
      transparent 100%
    );
    backdrop-filter: blur(1px);
    will-change: transform;
    animation: float linear infinite;
  }

  /* Variantes individuales */
  .sphere-1 {
    width: 420px;
    height: 420px;
    top: -100px;
    left: -80px;
    animation-duration: 22s;
    animation-delay: 0s;
    border-color: rgba(100, 160, 255, 0.15);
  }

  .sphere-2 {
    width: 280px;
    height: 280px;
    top: 20%;
    right: 5%;
    animation-duration: 18s;
    animation-delay: -6s;
    border-color: rgba(180, 210, 255, 0.1);
  }

  .sphere-3 {
    width: 160px;
    height: 160px;
    top: 55%;
    left: 15%;
    animation-duration: 14s;
    animation-delay: -3s;
    border-color: rgba(255, 255, 255, 0.08);
  }

  .sphere-4 {
    width: 500px;
    height: 500px;
    bottom: -150px;
    right: -100px;
    animation-duration: 26s;
    animation-delay: -10s;
    border-color: rgba(80, 140, 255, 0.12);
  }

  .sphere-7 {
    width: 340px;
    height: 340px;
    bottom: 10%;
    left: -60px;
    animation-duration: 24s;
    animation-delay: -14s;
    border-color: rgba(120, 170, 255, 0.1);
  }

  /* Animación de flotación suave */
  @keyframes float {
    0% {
      transform: translateY(0px) scale(1);
    }
    33% {
      transform: translateY(-18px) scale(1.01);
    }
    66% {
      transform: translateY(10px) scale(0.99);
    }
    100% {
      transform: translateY(0px) scale(1);
    }
  }

  /* Respetar modo de bajo movimiento */
  @media (prefers-reduced-motion: reduce) {
    .sphere {
      animation: none;
      will-change: auto;
    }
  }
</style>